[Unit]
Description=AsterQuanta OS - noeud DTN (Bundle Protocol, uD3TN)
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/bin/aqm-dtnd --eid dtn://aqm-node/ --aap2-socket /run/aqm/aqm-dtnd.aap.sock
Restart=always
RestartSec=5
RuntimeDirectory=aqm
User=aqm-service

[Install]
WantedBy=multi-user.target
